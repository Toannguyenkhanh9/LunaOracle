<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="16dp"
  android:background="@drawable/eastern_destiny_widget_background">

  <TextView
    android:id="@+id/widget_title"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Eastern Destiny"
    android:textColor="#D7AF5E"
    android:textSize="11sp"
    android:textStyle="bold"
    android:maxLines="1"/>

  <TextView
    android:id="@+id/widget_date"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:textColor="#FFF7E5"
    android:textSize="17sp"
    android:textStyle="bold"
    android:maxLines="1"/>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginTop="5dp">

    <TextView
      android:id="@+id/widget_lunar"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:textColor="#C8CFD9"
      android:textSize="10sp"
      android:maxLines="1"/>

    <TextView
      android:id="@+id/widget_can_chi"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textColor="#F0D18B"
      android:textSize="10sp"
      android:textStyle="bold"
      android:maxLines="1"/>
  </LinearLayout>

  <TextView
    android:id="@+id/widget_headline"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:layout_marginTop="9dp"
    android:textColor="#FFF2D4"
    android:textSize="13sp"
    android:textStyle="bold"
    android:gravity="center_vertical"
    android:maxLines="4"/>

  <TextView
    android:id="@+id/widget_profile"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:textColor="#AEB9C8"
    android:textSize="9sp"
    android:maxLines="1"/>
</LinearLayout>
